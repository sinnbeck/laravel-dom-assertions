{
    "name": "sinnbeck/laravel-dom-assertions",
    "homepage": "https://github.com/sinnbeck/laravel-dom-assertions",
    "license": "MIT",
    "keywords": [
        "laravel",
        "assertions",
        "view",
        "dom",
        "blade"
    ],
    "authors": [
        {
            "name": "René Sinnbeck",
            "email": "rene.sinnbeck@gmail.com",
            "homepage": "https://sinnbeck.dev",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "Sinnbeck\\DomAssertions\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Tests\\Views\\Components\\": "tests/views/components"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sinnbeck\\DomAssertions\\DomAssertionsServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.1",
        "ext-dom": "*",
        "ext-libxml": "*",
        "illuminate/testing": "^10.0|^11.0|^12.0|^13.0",
        "symfony/css-selector": "^6.0|^7.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.0|^3.0",
        "laravel/pint": "^1.2",
        "livewire/livewire": "^3.0|^4.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.34|^3.7|^3.8",
        "phpstan/extension-installer": "^1.2",
        "phpstan/phpstan-deprecation-rules": "^1.0|^2.0",
        "phpstan/phpstan-phpunit": "^1.1|^2.0",
        "rector/rector": "^2.3"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        },
        "sort-packages": true,
        "audit": {
            "ignore": {
                "GHSA-vvj3-c3rp-c85p": "Ensure testing features are compatible with affected PHPUnit versions"
            }
        }
    },
    "scripts": {
        "rector": "rector process"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
